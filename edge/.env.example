# ── Camera ────────────────────────────────────────────────────────
CAMERA_INDEX=0
DETECTION_INTERVAL=1.0       # seconds between AI runs
ALERT_COOLDOWN=15.0          # min seconds between POSTing alerts
CONFIDENCE_THRESHOLD=0.45
LOITERING_SECONDS=30.0       # seconds before loitering flag
MOTION_FILTER=true           # skip AI when no pixel change (saves energy)

# ── Models ────────────────────────────────────────────────────────
YOLO_MODEL=../yolov8n.pt
# Optional: path to a YOLOv8 weapons detection model
# Download: https://huggingface.co/keremberke/yolov8n-weapon-detection
WEAPONS_MODEL_PATH=

# ── Central server ────────────────────────────────────────────────
CENTRAL_URL=http://localhost:9000
INGEST_API_KEY=change-me-secret

# ── Device identity ───────────────────────────────────────────────
DEVICE_ID=edge-01
DEVICE_LOCATION=Main Entrance
SNAPSHOTS_DIR=static/snapshots
