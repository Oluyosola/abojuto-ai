# ──────────────────────────────────────────────
#  AbojutoAI — Environment Configuration
#  Copy this file to `.env` and fill in values
# ──────────────────────────────────────────────

# Camera Settings
CAMERA_INDEX=0              # 0 = default webcam
DETECTION_INTERVAL=1.0      # seconds between AI detection runs
ALERT_COOLDOWN=15.0         # min seconds between consecutive alerts
CONFIDENCE_THRESHOLD=0.5    # YOLOv8 person confidence (0.0–1.0)

# Email Alerts (Gmail example)
# For Gmail: enable 2FA → generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL=recipient@example.com

# Telegram Bot Alerts
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Add bot to a chat, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz
TELEGRAM_CHAT_ID=-100123456789
